<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Backoffice - Mascotero</title>
    <link rel="stylesheet" href="/css/estilos.css">
    <%- include('../partials/head') %>
</head>

<body>

    <%- include('../partials/header') %>

        <div class="backofficeContainer">
            <h2>Backoffice</h2>

            <% if (typeof cookie !== 'undefined' && cookie) { %>
                <p class="<%= cookie.tipo === 'exito' ? 'exito' : 'error' %>"><%= cookie.mensaje %></p>
            <% } %>

            <div class="backofficeAcciones">
                <button type="button" class="agregarBtn" onclick="window.location.href='/admin/alta'">Agregar
                    Producto</button>
                <button type="button" class="verVentasBtn" onclick="window.location.href='/admin/ventas'">Ver ventas</button>
                <form action="/admin/logout" method="post" class="logoutForm">
                    <button type="submit" class="logoutBtn">Logout</button>
                </form>
            </div>

            <div class="backofficeColumnas">
                <section class="backSection">
                    <h3>Accesorios</h3>
                    <p id="vacioAcc" hidden>No hay accesorios cargados.</p>
                    <div id="contenidoAcc" hidden>
                        <div class="backofficeBusquedaSeccion">
                            <label for="buscarAccInput">Buscar por nombre</label>
                            <div class="backofficeBusquedaFila">
                                <input type="search" id="buscarAccInput" placeholder="Nombre del producto..." autocomplete="off" />
                                <button type="button" id="buscarAccBtn" class="buscarBtn">Buscar</button>
                                <button type="button" id="limpiarAccBtn" class="limpiarBusquedaBtn" hidden>Limpiar</button>
                            </div>
                        </div>
                        <p id="sinCoincidenciasAcc" class="sinCoincidenciasBusqueda" hidden>No hay coincidencias en accesorios.</p>
                        <div id="gridAcc" class="productosGrid"></div>
                        <div class="pagination">
                            <a id="prevAcc" href="#" class="disabled">Anterior</a>
                            <span id="pageTextAcc">Página 0</span>
                            <a id="nextAcc" href="#">Siguiente</a>
                        </div>
                    </div>
                </section>

                <section class="backSection">
                    <h3>Alimentos</h3>
                    <p id="vacioAli" hidden>No hay alimentos cargados.</p>
                    <div id="contenidoAli" hidden>
                        <div class="backofficeBusquedaSeccion">
                            <label for="buscarAliInput">Buscar por nombre</label>
                            <div class="backofficeBusquedaFila">
                                <input type="search" id="buscarAliInput" placeholder="Nombre del producto..." autocomplete="off" />
                                <button type="button" id="buscarAliBtn" class="buscarBtn">Buscar</button>
                                <button type="button" id="limpiarAliBtn" class="limpiarBusquedaBtn" hidden>Limpiar</button>
                            </div>
                        </div>
                        <p id="sinCoincidenciasAli" class="sinCoincidenciasBusqueda" hidden>No hay coincidencias en alimentos.</p>
                        <div id="gridAli" class="productosGrid"></div>
                        <div class="pagination">
                            <a id="prevAli" href="#" class="disabled">Anterior</a>
                            <span id="pageTextAli">Página 0</span>
                            <a id="nextAli" href="#">Siguiente</a>
                        </div>
                    </div>
                </section>
            </div>

        </div>

        <div id="confirmarModal">
            <div class="modal">
                <p id="confirmarModalText"></p>
                <div class="modalActions">
                    <button type="button" class="modalConfirmar" id="confirmarModalOk">Confirmar</button>
                    <button type="button" class="modalCancelar" id="confirmarModalCancelar">Cancelar</button>
                </div>
            </div>
        </div>

        <script src="/js/paginadoAdmin.js"></script>
        <script src="/js/backofficeConfirmacion.js"></script>
        <script>
            const accesorios = __paginadoAdmin.iniciarProductos({
                apiUrl: "/api/admin/accesorios",
                tipo: "accesorio",
                gridId: "gridAcc",
                prevId: "prevAcc",
                nextId: "nextAcc",
                pageTextId: "pageTextAcc",
                buscarInputId: "buscarAccInput",
                buscarBtnId: "buscarAccBtn",
                limpiarBtnId: "limpiarAccBtn",
                sinCoincidenciasId: "sinCoincidenciasAcc",
                vacioId: "vacioAcc",
                contenidoId: "contenidoAcc"
            });

            const alimentos = __paginadoAdmin.iniciarProductos({
                apiUrl: "/api/admin/alimentos",
                tipo: "alimento",
                gridId: "gridAli",
                prevId: "prevAli",
                nextId: "nextAli",
                pageTextId: "pageTextAli",
                buscarInputId: "buscarAliInput",
                buscarBtnId: "buscarAliBtn",
                limpiarBtnId: "limpiarAliBtn",
                sinCoincidenciasId: "sinCoincidenciasAli",
                vacioId: "vacioAli",
                contenidoId: "contenidoAli"
            });

            window.addEventListener("load", () => {
                accesorios.cargarProductos();
                alimentos.cargarProductos();
            });
        </script>

</body>

</html>
