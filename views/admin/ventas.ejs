<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Venta productos - Mascotero</title>
    <link rel="stylesheet" href="/css/estilos.css">
    <%- include('../partials/head') %>
</head>

<body>

    <%- include('../partials/header') %>

        <div class="backofficeContainer">
            <div class="ventasEncabezado">
                <button type="button" class="volverBtn" onclick="window.location.href='/admin/backoffice'">Volver al backoffice</button>
                <h2>Venta productos</h2>
            </div>

            <% if (!pagVen.totalInventario) { %>
                <p>No hay registros en venta productos.</p>
            <% } else { %>
                <div class="ventasBusqueda">
                <%- include('../partials/busquedaSeccionAdmin', {
                    actionUrl: "/admin/ventas",
                    idInput: "buscarVenInput",
                    nombreCampo: "buscarVen",
                    valor: buscarVen,
                    labelText: "Buscar por descripción o ID",
                    placeholder: "Nombre del producto o ID del producto",
                    idInputFecha: "buscarFechaVenInput",
                    nombreCampoFecha: "buscarFechaVen",
                    valorFecha: buscarFechaVen,
                    labelTextFecha: "Buscar por fecha",
                    urlLimpiar: "/admin/ventas"
                }) %>
                </div>
                <% if (!pagVen.total) { %>
                    <p class="sinCoincidenciasBusqueda">No hay coincidencias.</p>
                <% } else { %>
                    <div class="ventasTabla">
                        <table>
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>ID Venta</th>
                                    <th>ID Accesorio</th>
                                    <th>ID Alimento</th>
                                    <th>Descripción</th>
                                    <th>Cantidad</th>
                                    <th>Precio unitario</th>
                                    <th>Precio total</th>
                                    <th>Fecha</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% ventaProductos.forEach(vp => { %>
                                    <tr>
                                        <td><%= vp.id %></td>
                                        <td><%= vp.id_venta %></td>
                                        <td><%= vp.id_accesorio ?? "-" %></td>
                                        <td><%= vp.id_alimento ?? "-" %></td>
                                        <td><%= vp.descripcion %></td>
                                        <td><%= vp.cantidad %></td>
                                        <td><%= vp.precioUnitarioFormateado %></td>
                                        <td><%= vp.precioFormateado %></td>
                                        <td><%= vp.fechaFormateada %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <%- include('../partials/paginacionVentas', {
                        buscarVen: buscarVen,
                        buscarFechaVen: buscarFechaVen,
                        hayAnterior: pagVen.hayAnterior,
                        haySiguiente: pagVen.haySiguiente,
                        numPagina: pagVen.numPagina
                    }) %>
                <% } %>
            <% } %>
        </div>

</body>

</html>
