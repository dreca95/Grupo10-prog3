<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Alta - Mascotero</title>
    <link rel="stylesheet" href="/css/estilos.css">
    <%- include('../partials/head') %>
</head>

<body>

    <%- include('../partials/header') %>

        <div class="container">
            <h1>Alta de Producto</h1>

            <% if (typeof error !== 'undefined') { %>
                <p class="error"><%= error %></p>
            <% } %>

            <form action="/admin/productos/alta" method="post" enctype="multipart/form-data">
                <div class="espacios">
                    <label for="tipo">Tipo de producto</label>
                    <select id="tipo" name="tipo" required>
                        <option value="">Seleccione...</option>
                        <option value="accesorio">Accesorio</option>
                        <option value="alimento">Alimento</option>
                    </select>
                </div>

                <div>
                    <label for="nombre">Nombre de producto</label>
                    <input id="nombre" name="nombre" type="text" required />
                </div>

                <div>
                    <label for="precio">Precio</label>
                    <input id="precio" name="precio" type="number" step="0.01" min="0" value="0" />
                    <p id="precioError" class="error" style="display: none;"></p>
                </div>

                <div>
                    <label for="descripcion">Descripción</label>
                    <textarea id="descripcion" name="descripcion" rows="4" required></textarea>
                </div>

                <div>
                    <label for="imagen">Imagen (JPG, JPEG o PNG - máx. 10 MB)</label>
                    <input id="imagen" name="imagen" type="file" accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
                </div>

                <button type="submit">Aceptar</button>
                <button type="button" class="cancelarBtn" onclick="window.history.back()">Cancelar</button>
            </form>
        </div>

        <%- include('../partials/footer') %>

        <script src="/js/validacionPrecio.js"></script>
        <script>initValidacionPrecio();</script>
</body>

</html>
