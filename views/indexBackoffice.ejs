<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Backoffice - Mascotero</title>
    <link rel="stylesheet" href="/css/estilos.css">
</head>

<body>

    <%- include('partials/header') %>

        <div class="backofficeContainer">
            <h2>Backoffice</h2>

            <% if (typeof cookie !== 'undefined' && cookie) { %>
                <p class="<%= cookie.tipo === 'exito' ? 'exito' : 'error' %>"><%= cookie.mensaje %></p>
            <% } %>

            <div class="backofficeColumnas">
                <section class="backSection">
                    <h3>Accesorios</h3>
                    <% if (accesorios && accesorios.length) { %>
                        <div class="productosGrid">
                            <% accesorios.forEach(a=> { %>
                                <div class="productoCard<%= a.estado === false ? ' inactivo' : '' %>">
                                    <% if (a.estado === false) { %>
                                        <span class="estadoInactivo">INACTIVO</span>
                                    <% } %>
                                    <div class="productoInfo">
                                        <strong>
                                            <%= a.nombre %>
                                        </strong>
                                        <p>Precio: <%= a.precio %>
                                        </p>
                                        <% if (a.descripcion) { %>
                                            <p>
                                                Descripción: <%= a.descripcion %>
                                            </p>
                                            <% } %>
                                    </div>
                                    <div class="productoActions">
                                        <% if (a.estado === false) { %>
                                            <form action="/productos/activar/accesorio/<%= a.id %>" method="post"
                                                class="activarForm">
                                                <button type="submit" class="productoBtn activarBtn">Activar</button>
                                            </form>
                                        <% } else { %>
                                            <button type="button" class="productoBtn editarBtn"
                                                onclick="window.location.href='/edicion/accesorio/<%= a.id %>'">Editar</button>
                                            <form action="/productos/baja/accesorio/<%= a.id %>" method="post"
                                                class="bajaForm">
                                                <button type="submit" class="productoBtn eliminarBtn">Eliminar</button>
                                            </form>
                                        <% } %>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                        <% } else { %>
                            <p>No hay accesorios cargados.</p>
                            <% } %>
                </section>

                <section class="backSection">
                    <h3>Alimentos</h3>
                    <% if (alimentos && alimentos.length) { %>
                        <div class="productosGrid">
                            <% alimentos.forEach(p=> { %>
                                <div class="productoCard<%= p.estado === false ? ' inactivo' : '' %>">
                                    <% if (p.estado === false) { %>
                                        <span class="estadoInactivo">INACTIVO</span>
                                    <% } %>
                                    <div class="productoInfo">
                                        <strong>
                                            <%= p.nombre %>
                                        </strong>
                                        <p>Precio: <%= p.precio %>
                                        </p>
                                        <% if (p.descripcion) { %>
                                            <p>
                                                Descripción: <%= p.descripcion %>
                                            </p>
                                            <% } %>
                                    </div>
                                    <div class="productoActions">
                                        <% if (p.estado === false) { %>
                                            <form action="/productos/activar/alimento/<%= p.id %>" method="post"
                                                class="activarForm">
                                                <button type="submit" class="productoBtn activarBtn">Activar</button>
                                            </form>
                                        <% } else { %>
                                            <button type="button" class="productoBtn editarBtn"
                                                onclick="window.location.href='/edicion/alimento/<%= p.id %>'">Editar</button>
                                            <form action="/productos/baja/alimento/<%= p.id %>" method="post"
                                                class="bajaForm">
                                                <button type="submit" class="productoBtn eliminarBtn">Eliminar</button>
                                            </form>
                                        <% } %>
                                    </div>
                                </div>
                                <% }) %>
                        </div>
                        <% } else { %>
                            <p>No hay alimentos cargados.</p>
                            <% } %>
                </section>
            </div>

            <div>
                <button type="button" class="agregarBtn btn btn-primary" onclick="window.location.href='/alta'">Agregar
                    Producto</button>
            </div>

        </div>

</body>

</html>
