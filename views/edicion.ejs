<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Edición - Mascotero</title>
    <link rel="stylesheet" href="/css/estilos.css">
</head>

<body>

    <%- include('partials/header') %>

        <div class="container">
            <h1>Edición de Producto</h1>

            <% if (typeof error !== 'undefined') { %>
                <p class="error"><%= error %></p>
            <% } %>

            <form action="/productos/edicion/<%= tipo %>/<%= producto.id %>" method="post">

                <div class="espacios">
                    <label for="tipo">Tipo de producto</label>
                    <select id="tipo" name="tipo" required>
                        <option value="accesorio" <%= tipo === 'accesorio' ? 'selected' : '' %>>Accesorio</option>
                        <option value="alimento" <%= tipo === 'alimento' ? 'selected' : '' %>>Alimento</option>
                    </select>
                </div>

                <div>
                    <label for="nombre">Nombre de producto</label>
                    <input id="nombre" name="nombre" type="text" required value="<%= producto.nombre %>" />
                </div>

                <div>
                    <label for="precio">Precio</label>
                    <input id="precio" name="precio" type="number" step="0.01" min="0"
                        value="<%= producto.precio ?? 0 %>" />
                    <p id="precioError" class="error" style="display: none;"></p>
                </div>

                <div>
                    <label for="descripcion">Descripción</label>
                    <textarea id="descripcion" name="descripcion" rows="4"
                        required><%= producto.descripcion %></textarea>
                </div>

                <button type="submit">Guardar cambios</button>
                <button type="button" class="cancelarBtn" onclick="window.history.back()">Cancelar</button>
            </form>
        </div>

        <%- include('partials/footer') %>

        <script src="/js/validacionPrecio.js"></script>
        <script>initValidacionPrecio();</script>
</body>

</html>
